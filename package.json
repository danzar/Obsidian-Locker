{
	"name": "note-locker",
	"version": "0.5.0",
	"description": "Encrypt note contents at rest while keeping the title visible.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node src/.tests/locker.test.mjs && node src/.tests/orchestration.test.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"encryption",
		"privacy"
	],
	"author": "Zarware",
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.20.0",
		"obsidian": "latest",
		"tslib": "2.6.2",
		"typescript": "5.3.3"
	}
}
